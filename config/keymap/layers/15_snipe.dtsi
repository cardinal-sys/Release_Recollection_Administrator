/* ============================================================
 * layers/15_snipe.dtsi 芒聙聰 [ Synthesis 15 ] SNIPE
 *
 * 茫聝聡茫聝聲茫聜漏茫聝芦茫聝聢茫聝卢茫聜陇茫聝陇茫聝录茫聛篓茫聛禄茫聛录氓聬聦盲赂聙茫聝聬茫聜陇茫聝鲁茫聝聣茫聙聜K 茫聛庐茫聛驴茫聝聸茫聝录茫聝芦茫聝聣茫聛搂 arrows_alt 猫碌路氓聥聲茫聙聜
 * K 茫聝聸茫聝录茫聝芦茫聝聣盲赂颅: arrows-alt-profiles 茫聛庐 L15 茫聜篓茫聝鲁茫聝聢茫聝陋茂录聢茫聜鲁茫聝录茫聝聣 2000-2003茂录聣茫聛聦
 * 茫聝聻茫聝聝茫聝聛茫聛聴茫聛娄茫聝聢茫聝漏茫聝聝茫聜炉茫聝聹茫聝录茫聝芦氓聥聲盲陆聹茫聛聦茫聜鹿茫聜炉茫聝颅茫聝录茫聝芦茫聝聸茫聜陇茫聝录茫聝芦茫聜陇茫聝聶茫聝鲁茫聝聢茫聛芦氓陇聣忙聫聸茫聛聲茫聜聦茫聜聥茫聙聜
 * 茫聝聢茫聝漏茫聝聝茫聜炉茫聝聹茫聝录茫聝芦 CPI 茫聛炉茫聝聣茫聝漏茫聜陇茫聝聬茫聛聦 snipe-layers 猫篓颅氓庐職茫聛芦茫聜聢茫聜聤猫聡陋氓聥聲茫聛搂盲陆聨忙赂聸茫聛聶茫聜聥茫聙聜
 * ============================================================ */

SNIPE {
    bindings = <
    &trans  &mt LCTRL_RSHFT_RALT_RGUI Q  /* GESTURE_MO_KP(14,458778) */  /* GESTURE_MO_KP(7,458760) */  /* GESTURE_MO_KP(8,458773) */  /* GESTURE_MO_KP(11,458775) */  &kp Y  &kp U  /* GESTURE_MO_KP(5,458764) */  &kp O  &mt LCTRL_LALT_RSHFT_RALT_RGUI P  &trans  &trans  /* GESTURE_MO_KP(12,458756) */  /* GESTURE_MO_KP(9,458774) */  /* GESTURE_MO_KP(13,458759) */  &kp F  &lt 6 G  /* smart_num(16,0) */  &kp LLSHFT(NUMBER_2)  &kp H  &kp J  /* ht_arrows_alt(15,458766) */  /* GESTURE_MO_KP(4,458767) */  &mt LCTRL_LSHFT_RSHFT_RALT_RGUI MINUS  &trans  &trans  &kp Z  &kp X  &kp C  &kp V  /* GESTURE_MO_KP(10,458757) */  &kp TAB  &kp LLSHFT(SEMICOLON)  &kp N  &kp M  &kp COMMA  &kp PERIOD  &mt RSHFT_RALT_RGUI EQUAL  &trans  &trans  &kp LEFT_CONTROL  &kp LEFT_GUI  &kp LEFT_ALT  &lt 2 ESC  &lt 3 SPACE  &mkp MB1  &kp BACKSPACE  &lt 1 ENTER  &mt LSHFT_RSHFT_RALT_RGUI DELETE  &trans
    >;

    sensor-bindings = <&inc_dec_kp DOWN_ARROW UP_ARROW>;
};
